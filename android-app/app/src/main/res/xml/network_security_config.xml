<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- ABSOLUTE TRUST: This tells Android to trust the Railway domain even on restricted mobile networks -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">surveysetu-production.up.railway.app</domain>
        <domain includeSubdomains="true">railway.app</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
